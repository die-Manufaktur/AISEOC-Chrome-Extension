{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "768px",
      "wideSize": "1280px"
    },
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "defaultDuotone": false,
      "palette": [
        {
          "slug": "primary",
          "color": "#db394e",
          "name": "Primary (Cerise Red)"
        },
        {
          "slug": "accent",
          "color": "#f3d245",
          "name": "Accent (Saffron)"
        },
        {
          "slug": "accent-lighter",
          "color": "#fcf6d9",
          "name": "Accent Lighter"
        },
        {
          "slug": "secondary",
          "color": "#18365d",
          "name": "Secondary (Biscay)"
        },
        {
          "slug": "secondary-lightest",
          "color": "#e7eaee",
          "name": "Secondary Lightest"
        },
        {
          "slug": "dark-gray",
          "color": "#494b4a",
          "name": "Dark Gray (Cape Cod)"
        },
        {
          "slug": "light-gray",
          "color": "#ecedec",
          "name": "Light Gray"
        },
        {
          "slug": "white",
          "color": "#ffffff",
          "name": "White"
        },
        {
          "slug": "black",
          "color": "#010305",
          "name": "Black"
        },
        {
          "slug": "text-dark",
          "color": "#1d1e1d",
          "name": "Text Dark"
        }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "slug": "primary",
          "fontFamily": "\"Poppins\", \"system-ui\", \"-apple-system\", \"BlinkMacSystemFont\", \"Segoe UI\", \"Roboto\", \"sans-serif\"",
          "name": "Primary (Poppins)"
        },
        {
          "slug": "heading",
          "fontFamily": "\"Source Sans 3\", \"Georgia\", \"serif\"",
          "name": "Heading (Source Sans 3)"
        }
      ],
      "fontSizes": [
        {
          "slug": "tiny",
          "size": "12px",
          "name": "Tiny"
        },
        {
          "slug": "small",
          "size": "14px",
          "name": "Small"
        },
        {
          "slug": "base",
          "size": "16px",
          "name": "Base"
        },
        {
          "slug": "medium",
          "size": "18px",
          "name": "Medium"
        },
        {
          "slug": "large",
          "size": "20px",
          "name": "Large (H6)"
        },
        {
          "slug": "x-large",
          "size": "24px",
          "name": "Extra Large (H5)"
        },
        {
          "slug": "2-x-large",
          "size": "32px",
          "name": "2X Large"
        },
        {
          "slug": "3-x-large",
          "size": "40px",
          "name": "3X Large (H3)"
        },
        {
          "slug": "4-x-large",
          "size": "48px",
          "name": "4X Large (H2)"
        },
        {
          "slug": "5-x-large",
          "size": "56px",
          "name": "5X Large (H1)"
        }
      ],
      "fontWeight": true,
      "lineHeight": true,
      "textDecoration": true,
      "textTransform": true
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "spacingSizes": [
        {
          "slug": "20",
          "size": "4px",
          "name": "1"
        },
        {
          "slug": "30",
          "size": "8px",
          "name": "2"
        },
        {
          "slug": "40",
          "size": "16px",
          "name": "3"
        },
        {
          "slug": "50",
          "size": "24px",
          "name": "4"
        },
        {
          "slug": "60",
          "size": "32px",
          "name": "5"
        },
        {
          "slug": "70",
          "size": "40px",
          "name": "6"
        },
        {
          "slug": "80",
          "size": "48px",
          "name": "7"
        },
        {
          "slug": "90",
          "size": "64px",
          "name": "8"
        },
        {
          "slug": "100",
          "size": "80px",
          "name": "9"
        },
        {
          "slug": "110",
          "size": "112px",
          "name": "10"
        }
      ],
      "units": ["px", "em", "rem", "vh", "vw", "%"]
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        {
          "slug": "sm",
          "shadow": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
          "name": "Small"
        },
        {
          "slug": "base",
          "shadow": "0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06)",
          "name": "Base"
        },
        {
          "slug": "md",
          "shadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
          "name": "Medium"
        },
        {
          "slug": "lg",
          "shadow": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
          "name": "Large"
        },
        {
          "slug": "xl",
          "shadow": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)",
          "name": "Extra Large"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--black)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--primary)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--secondary)"
          }
        }
      },
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--5-x-large)",
          "fontWeight": "400",
          "lineHeight": "1.2"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--4-x-large)",
          "fontWeight": "400",
          "lineHeight": "1.2"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--3-x-large)",
          "fontWeight": "400",
          "lineHeight": "1.2"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--2-x-large)",
          "fontWeight": "400",
          "lineHeight": "1.4"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "fontWeight": "400",
          "lineHeight": "1.4"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--large)",
          "fontWeight": "400",
          "lineHeight": "1.4"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--base)",
          "fontWeight": "600"
        },
        "border": {
          "radius": "4px"
        },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--40)",
            "right": "var(--wp--preset--spacing--50)",
            "bottom": "var(--wp--preset--spacing--40)",
            "left": "var(--wp--preset--spacing--50)"
          }
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--secondary)"
          }
        }
      }
    },
    "blocks": {
      "core/button": {
        "variations": {
          "outline": {
            "color": {
              "background": "transparent",
              "text": "var(--wp--preset--color--primary)"
            },
            "border": {
              "color": "var(--wp--preset--color--primary)",
              "width": "2px"
            },
            ":hover": {
              "color": {
                "background": "var(--wp--preset--color--primary)",
                "text": "var(--wp--preset--color--white)"
              }
            }
          }
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "customTemplates": [
    {
      "name": "page-learn-about-rcv",
      "title": "Learn About RCV",
      "postTypes": ["page"]
    },
    {
      "name": "page-about",
      "title": "About",
      "postTypes": ["page"]
    },
    {
      "name": "page-contact",
      "title": "Contact",
      "postTypes": ["page"]
    },
    {
      "name": "page-services",
      "title": "Services",
      "postTypes": ["page"]
    }
  ]
}
