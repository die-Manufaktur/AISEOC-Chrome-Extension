{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "neutral-darkest",
					"color": "#050704",
					"name": "Neutral Darkest"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				},
				{
					"slug": "dark-muted",
					"color": "#1e1f1d",
					"name": "Dark Muted"
				},
				{
					"slug": "blue-zodiac",
					"color": "#0b2340",
					"name": "Blue Zodiac"
				},
				{
					"slug": "white-20",
					"color": "#ffffff33",
					"name": "White 20%"
				},
				{
					"slug": "neutral-15",
					"color": "#05070426",
					"name": "Neutral 15%"
				},
				{
					"slug": "transparent",
					"color": "#ffffff00",
					"name": "Transparent"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"fontFamily": "\"Fraunces\", Georgia, serif",
					"name": "Fraunces",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Fraunces",
							"fontWeight": "700",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"https://fonts.gstatic.com/s/fraunces/v31/6NUh8FyLNQOQZAnv9bYEvDiIdE9Ea92uemAk_WBq8U_9v0c2Wa0K7iN7hzFUPJH58nk.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "\"Merriweather Sans\", system-ui, -apple-system, sans-serif",
					"name": "Merriweather Sans",
					"slug": "body",
					"fontFace": [
						{
							"fontFamily": "Merriweather Sans",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"https://fonts.gstatic.com/s/merriweathersans/v26/2-cO9IRs1JiJN1FRAMjTN5zd9vgsFF_5asQTb6hZ2JKZou4ljuEG7xFHnQ.woff2"
							]
						},
						{
							"fontFamily": "Merriweather Sans",
							"fontWeight": "700",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"https://fonts.gstatic.com/s/merriweathersans/v26/2-cO9IRs1JiJN1FRAMjTN5zd9vgsFF_5asQTb6hZ2JKZou4ljuEG7xFHnQ.woff2"
							]
						}
					]
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "16px",
					"name": "Small",
					"fluid": {
						"min": "14px",
						"max": "16px"
					}
				},
				{
					"slug": "base",
					"size": "18px",
					"name": "Base",
					"fluid": {
						"min": "16px",
						"max": "18px"
					}
				},
				{
					"slug": "medium",
					"size": "20px",
					"name": "Medium",
					"fluid": {
						"min": "18px",
						"max": "20px"
					}
				},
				{
					"slug": "large",
					"size": "32px",
					"name": "Large",
					"fluid": {
						"min": "24px",
						"max": "32px"
					}
				},
				{
					"slug": "x-large",
					"size": "60px",
					"name": "Extra Large",
					"fluid": {
						"min": "36px",
						"max": "60px"
					}
				},
				{
					"slug": "xx-large",
					"size": "84px",
					"name": "2X Large",
					"fluid": {
						"min": "48px",
						"max": "84px"
					}
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{
					"slug": "10",
					"size": "8px",
					"name": "1"
				},
				{
					"slug": "20",
					"size": "16px",
					"name": "2"
				},
				{
					"slug": "30",
					"size": "24px",
					"name": "3"
				},
				{
					"slug": "40",
					"size": "32px",
					"name": "4"
				},
				{
					"slug": "50",
					"size": "40px",
					"name": "5"
				},
				{
					"slug": "60",
					"size": "48px",
					"name": "6"
				},
				{
					"slug": "70",
					"size": "64px",
					"name": "7"
				},
				{
					"slug": "80",
					"size": "80px",
					"name": "8"
				},
				{
					"slug": "90",
					"size": "112px",
					"name": "9"
				}
			],
			"units": [
				"px",
				"em",
				"rem",
				"%",
				"vw",
				"vh"
			]
		},
		"layout": {
			"contentSize": "768px",
			"wideSize": "1280px"
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--neutral-darkest)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.6"
		},
		"spacing": {
			"padding": {
				"left": "var(--wp--preset--spacing--70)",
				"right": "var(--wp--preset--spacing--70)"
			},
			"blockGap": "0"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "700",
					"letterSpacing": "1px"
				},
				"color": {
					"text": "var(--wp--preset--color--neutral-darkest)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"lineHeight": "1.1"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"lineHeight": "1.2"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"lineHeight": "1.4"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"lineHeight": "1.2"
				}
			},
			"link": {
				"color": {
					"text": "inherit"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--blue-zodiac)"
					}
				},
				"typography": {
					"textDecoration": "none"
				}
			},
			"button": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "700",
					"lineHeight": "1.5"
				},
				"color": {
					"background": "var(--wp--preset--color--neutral-darkest)",
					"text": "var(--wp--preset--color--white)"
				},
				"border": {
					"radius": "0px",
					"width": "1px",
					"color": "var(--wp--preset--color--neutral-darkest)"
				},
				"spacing": {
					"padding": {
						"top": "8px",
						"bottom": "8px",
						"left": "20px",
						"right": "20px"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--white)",
						"text": "var(--wp--preset--color--neutral-darkest)"
					}
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "400"
				}
			},
			"core/quote": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontStyle": "normal"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--neutral-15)"
				},
				"border": {
					"width": "1px"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "page-about",
			"title": "About",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-become-a-mason",
			"title": "Become a Mason",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-foundation",
			"title": "Foundation & Scholarships",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-contact",
			"title": "Contact",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-member-portal",
			"title": "Member Portal",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-events",
			"title": "Events",
			"postTypes": [
				"page"
			]
		}
	]
}
