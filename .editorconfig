# EditorConfig - React/TypeScript Conventions
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# TypeScript & JavaScript
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_style = space
indent_size = 2

# CSS & Styling
[*.{css,scss,sass,less}]
indent_style = space
indent_size = 2

# HTML & Templates
[*.{html,htm}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2

# Config files
[{package.json,tsconfig.json,tsconfig.*.json}]
indent_style = space
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab
